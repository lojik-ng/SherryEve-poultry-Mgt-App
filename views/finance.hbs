<div class="page-header">
    <div class="page-header-info">
        <h2>💰 Financial Management</h2>
        <p>Track income, expenses, and profitability</p>
    </div>
    <div class="page-header-actions">
        {{#canDo 'finance' 'create'}}
        <button class="btn btn-success" data-modal="modalAddIncome">+ Add Income</button>
        <button class="btn btn-danger" data-modal="modalAddExpense">+ Add Expense</button>
        {{/canDo}}
    </div>
</div>

<div class="stats-grid">
    <div class="stat-card stat-success">
        <div class="stat-icon">💰</div>
        <div class="stat-info-text">
            <div class="stat-label">Today's Income</div>
            <div class="stat-value">{{formatCurrency todayIncome}}</div>
        </div>
    </div>
    <div class="stat-card stat-danger">
        <div class="stat-icon">💸</div>
        <div class="stat-info-text">
            <div class="stat-label">Today's Expenses</div>
            <div class="stat-value">{{formatCurrency todayExpense}}</div>
        </div>
    </div>
    <div class="stat-card stat-primary">
        <div class="stat-icon">📈</div>
        <div class="stat-info-text">
            <div class="stat-label">Today's Profit</div>
            <div class="stat-value">{{formatCurrency todayProfit}}</div>
            <div class="stat-change {{#if (gte todayProfit 0)}}positive{{else}}negative{{/if}}">{{#if (gte todayProfit
                0)}}↑ Profit{{else}}↓ Loss{{/if}}</div>
        </div>
    </div>
    <div class="stat-card stat-info">
        <div class="stat-icon">📊</div>
        <div class="stat-info-text">
            <div class="stat-label">Monthly P&L</div>
            <div class="stat-value">{{formatCurrency monthProfit}}</div>
            <div class="stat-change {{#if (gte monthProfit 0)}}positive{{else}}negative{{/if}}">Income: {{formatCurrency
                monthIncome}} | Exp: {{formatCurrency monthExpense}}</div>
        </div>
    </div>
</div>

<div class="grid-2 mb-3">
    <div class="card">
        <div class="card-header">
            <h3>Income by Category (This Month)</h3>
        </div>
        <div class="card-body">
            {{#if incomeByCategory.length}}
            <ul class="alert-list">
                {{#each incomeByCategory}}
                <li class="alert-item"><span class="alert-name">{{this.category}}</span><span
                        class="text-success font-semibold">{{formatCurrency this.total}}</span></li>
                {{/each}}
            </ul>
            {{else}}<div class="empty-state">
                <p>No income this month</p>
            </div>{{/if}}
        </div>
    </div>
    <div class="card">
        <div class="card-header">
            <h3>Expenses by Category (This Month)</h3>
        </div>
        <div class="card-body">
            {{#if expenseByCategory.length}}
            <ul class="alert-list">
                {{#each expenseByCategory}}
                <li class="alert-item"><span class="alert-name">{{this.category}}</span><span
                        class="text-danger font-semibold">{{formatCurrency this.total}}</span></li>
                {{/each}}
            </ul>
            {{else}}<div class="empty-state">
                <p>No expenses this month</p>
            </div>{{/if}}
        </div>
    </div>
</div>

<!-- Tabs: Income / Expenses -->
<div class="card">
    <div class="card-body" style="padding-top: 0;">
        <div class="tabs">
            <button class="tab active" data-tab="tabIncome">Income Records</button>
            <button class="tab" data-tab="tabExpenses">Expense Records</button>
        </div>

        <div id="tabIncome" class="tab-content active">
            {{#if incomes.length}}
            <div class="table-container">
                <table class="data-table">
                    <thead>
                        <tr>
                            <th>Date</th>
                            <th>Category</th>
                            <th>Amount</th>
                            <th>Description</th>
                            <th>By</th>
                        </tr>
                    </thead>
                    <tbody>
                        {{#each incomes}}
                        <tr>
                            <td>{{formatDate this.income_date}}</td>
                            <td><span class="badge badge-success">{{this.category}}</span></td>
                            <td class="text-success font-bold">{{formatCurrency this.amount}}</td>
                            <td>{{this.description}}</td>
                            <td>{{this.created_by_name}}</td>
                        </tr>
                        {{/each}}
                    </tbody>
                </table>
            </div>
            {{else}}<div class="empty-state">
                <p>No income records</p>
            </div>{{/if}}
        </div>

        <div id="tabExpenses" class="tab-content">
            {{#if expenses.length}}
            <div class="table-container">
                <table class="data-table">
                    <thead>
                        <tr>
                            <th>Date</th>
                            <th>Category</th>
                            <th>Amount</th>
                            <th>Description</th>
                            <th>By</th>
                        </tr>
                    </thead>
                    <tbody>
                        {{#each expenses}}
                        <tr>
                            <td>{{formatDate this.expense_date}}</td>
                            <td><span class="badge badge-danger">{{this.category}}</span></td>
                            <td class="text-danger font-bold">{{formatCurrency this.amount}}</td>
                            <td>{{this.description}}</td>
                            <td>{{this.created_by_name}}</td>
                        </tr>
                        {{/each}}
                    </tbody>
                </table>
            </div>
            {{else}}<div class="empty-state">
                <p>No expense records</p>
            </div>{{/if}}
        </div>
    </div>
</div>

<!-- Add Income Modal -->
{{#canDo 'finance' 'create'}}
<div class="modal-overlay" id="modalAddIncome">
    <div class="modal">
        <div class="modal-header">
            <h3>💰 Add Income</h3><button class="modal-close">✕</button>
        </div>
        <form action="/finance/income" method="POST" data-async>
            <div class="modal-body">
                <div class="form-group"><label>Category <span class="required">*</span></label>
                    <select class="form-control" name="category" required>
                        <option value="Bird Sales">Bird Sales</option>
                        <option value="Egg Sales">Egg Sales</option>
                        <option value="Other Income">Other Income</option>
                    </select>
                </div>
                <div class="form-group"><label>Amount <span class="required">*</span></label><input type="number"
                        class="form-control" name="amount" required step="0.01" min="0.01"></div>
                <div class="form-group"><label>Description</label><input type="text" class="form-control"
                        name="description"></div>
                <div class="form-group"><label>Date</label><input type="date" class="form-control" name="income_date">
                </div>
            </div>
            <div class="modal-footer"><button type="button" class="btn btn-outline"
                    data-dismiss="modal">Cancel</button><button type="submit" class="btn btn-success">Save
                    Income</button></div>
        </form>
    </div>
</div>

<!-- Add Expense Modal -->
<div class="modal-overlay" id="modalAddExpense">
    <div class="modal">
        <div class="modal-header">
            <h3>💸 Add Expense</h3><button class="modal-close">✕</button>
        </div>
        <form action="/finance/expense" method="POST" data-async>
            <div class="modal-body">
                <div class="form-group"><label>Category <span class="required">*</span></label>
                    <select class="form-control" name="category" required>
                        <option value="Feed Purchases">Feed Purchases</option>
                        <option value="Bird Purchases">Bird Purchases</option>
                        <option value="Medication">Medication</option>
                        <option value="Utilities">Utilities</option>
                        <option value="Staff Wages">Staff Wages</option>
                        <option value="Maintenance">Maintenance</option>
                        <option value="Other">Other</option>
                    </select>
                </div>
                <div class="form-group"><label>Amount <span class="required">*</span></label><input type="number"
                        class="form-control" name="amount" required step="0.01" min="0.01"></div>
                <div class="form-group"><label>Description</label><input type="text" class="form-control"
                        name="description"></div>
                <div class="form-group"><label>Date</label><input type="date" class="form-control" name="expense_date">
                </div>
            </div>
            <div class="modal-footer"><button type="button" class="btn btn-outline"
                    data-dismiss="modal">Cancel</button><button type="submit" class="btn btn-danger">Save
                    Expense</button></div>
        </form>
    </div>
</div>
{{/canDo}}