<div class="page-header">
    <div class="page-header-info">
        <h2>🥚 Egg Management</h2>
        <p>Track egg collections, sales, and losses</p>
    </div>
    <div class="page-header-actions">
        <button class="btn btn-success" data-modal="modalEggCollect">+ Collection</button>
        <button class="btn btn-primary" data-modal="modalEggSell">+ Sale</button>
        <button class="btn btn-danger" data-modal="modalEggLoss">+ Loss</button>
    </div>
</div>

<div class="stats-grid">
    <div class="stat-card stat-accent">
        <div class="stat-icon">🥚</div>
        <div class="stat-info-text">
            <div class="stat-label">Current Egg Stock</div>
            <div class="stat-value">{{formatNumber eggStock.quantity}}</div>
            {{#if (lte eggStock.quantity eggStock.low_stock_threshold)}}
            <div class="stat-change negative">⚠ Below threshold ({{eggStock.low_stock_threshold}})</div>
            {{/if}}
        </div>
    </div>
    <div class="stat-card stat-warning">
        <div class="stat-icon">⚙️</div>
        <div class="stat-info-text">
            <div class="stat-label">Low Stock Threshold</div>
            <div class="stat-value">{{formatNumber eggStock.low_stock_threshold}}</div>
        </div>
    </div>
</div>

<!-- Transaction History -->
<div class="card">
    <div class="card-header">
        <h3>Transaction History</h3>
    </div>
    <div class="card-body">
        {{#if transactions.length}}
        <div class="table-container">
            <table class="data-table">
                <thead>
                    <tr>
                        <th>Date</th>
                        <th>Type</th>
                        <th>Qty</th>
                        <th>Unit Price</th>
                        <th>Total</th>
                        <th>Customer</th>
                        <th>Loss Reason</th>
                        <th>Notes</th>
                        <th>By</th>
                    </tr>
                </thead>
                <tbody>
                    {{#each transactions}}
                    <tr>
                        <td>{{formatDate this.transaction_date}}</td>
                        <td>{{{statusBadge this.transaction_type}}}</td>
                        <td>{{formatNumber this.quantity}}</td>
                        <td>{{#if this.unit_price}}{{formatCurrency this.unit_price}}{{else}}—{{/if}}</td>
                        <td>{{#if this.total_amount}}{{formatCurrency this.total_amount}}{{else}}—{{/if}}</td>
                        <td>{{#if this.customer_name}}{{this.customer_name}}{{else}}—{{/if}}</td>
                        <td>{{#if this.loss_reason}}{{this.loss_reason}}{{else}}—{{/if}}</td>
                        <td>{{#if this.notes}}{{truncate this.notes 30}}{{else}}—{{/if}}</td>
                        <td>{{this.created_by_name}}</td>
                    </tr>
                    {{/each}}
                </tbody>
            </table>
        </div>
        {{else}}
        <div class="empty-state">
            <div class="empty-icon">🥚</div>
            <h3>No Egg Transactions</h3>
            <p>Start recording egg collections</p>
        </div>
        {{/if}}
    </div>
</div>

<!-- Egg Collection Modal -->
<div class="modal-overlay" id="modalEggCollect">
    <div class="modal">
        <div class="modal-header">
            <h3>🥚 Egg Collection</h3><button class="modal-close">✕</button>
        </div>
        <form action="/eggs/transaction" method="POST" data-async>
            <input type="hidden" name="transaction_type" value="collection">
            <div class="modal-body">
                <div class="form-group">
                    <label>Quantity <span class="required">*</span></label>
                    <input type="number" class="form-control" name="quantity" required min="1"
                        placeholder="Number of eggs collected">
                </div>
                <div class="form-group">
                    <label>Date</label>
                    <input type="date" class="form-control" name="transaction_date">
                </div>
                <div class="form-group">
                    <label>Notes</label>
                    <textarea class="form-control" name="notes" rows="2"></textarea>
                </div>
            </div>
            <div class="modal-footer">
                <button type="button" class="btn btn-outline" data-dismiss="modal">Cancel</button>
                <button type="submit" class="btn btn-success">Save Collection</button>
            </div>
        </form>
    </div>
</div>

<!-- Egg Sale Modal -->
<div class="modal-overlay" id="modalEggSell">
    <div class="modal">
        <div class="modal-header">
            <h3>💰 Egg Sale</h3><button class="modal-close">✕</button>
        </div>
        <form action="/eggs/transaction" method="POST" data-async>
            <input type="hidden" name="transaction_type" value="sale">
            <div class="modal-body">
                <div class="form-row">
                    <div class="form-group">
                        <label>Quantity <span class="required">*</span></label>
                        <input type="number" class="form-control" name="quantity" required min="1">
                    </div>
                    <div class="form-group">
                        <label>Unit Price</label>
                        <input type="number" class="form-control" name="unit_price" step="0.01">
                    </div>
                </div>
                <div class="form-group">
                    <label>Total Amount</label>
                    <input type="number" class="form-control" name="total_amount" step="0.01" readonly>
                </div>
                <div class="form-group">
                    <label>Customer</label>
                    <select class="form-control" name="customer_id">
                        <option value="">— Select —</option>
                        {{#each customers}}<option value="{{this.id}}">{{this.name}}</option>{{/each}}
                    </select>
                </div>
                <div class="form-group">
                    <label>Notes</label>
                    <textarea class="form-control" name="notes" rows="2"></textarea>
                </div>
            </div>
            <div class="modal-footer">
                <button type="button" class="btn btn-outline" data-dismiss="modal">Cancel</button>
                <button type="submit" class="btn btn-success">Record Sale</button>
            </div>
        </form>
    </div>
</div>

<!-- Egg Loss Modal -->
<div class="modal-overlay" id="modalEggLoss">
    <div class="modal">
        <div class="modal-header">
            <h3>⚠ Egg Loss</h3><button class="modal-close">✕</button>
        </div>
        <form action="/eggs/transaction" method="POST" data-async>
            <input type="hidden" name="transaction_type" value="loss">
            <div class="modal-body">
                <div class="form-group">
                    <label>Quantity <span class="required">*</span></label>
                    <input type="number" class="form-control" name="quantity" required min="1">
                </div>
                <div class="form-group">
                    <label>Loss Reason <span class="required">*</span></label>
                    <select class="form-control" name="loss_reason" required>
                        <option value="breakage">Breakage</option>
                        <option value="spoilage">Spoilage</option>
                        <option value="theft">Theft</option>
                        <option value="other">Other</option>
                    </select>
                </div>
                <div class="form-group">
                    <label>Notes</label>
                    <textarea class="form-control" name="notes" rows="2"></textarea>
                </div>
            </div>
            <div class="modal-footer">
                <button type="button" class="btn btn-outline" data-dismiss="modal">Cancel</button>
                <button type="submit" class="btn btn-danger">Record Loss</button>
            </div>
        </form>
    </div>
</div>