<!-- Dashboard KPI Stats -->
<div class="stats-grid">
    <div class="stat-card stat-primary">
        <div class="stat-icon">🐔</div>
        <div class="stat-info-text">
            <div class="stat-label">Total Birds</div>
            <div class="stat-value">{{formatNumber totalBirds}}</div>
        </div>
    </div>

    <div class="stat-card stat-accent">
        <div class="stat-icon">🥚</div>
        <div class="stat-info-text">
            <div class="stat-label">Eggs in Stock</div>
            <div class="stat-value">{{formatNumber eggStock.quantity}}</div>
            {{#if (lte eggStock.quantity eggStock.low_stock_threshold)}}
            <div class="stat-change negative">⚠ Below threshold</div>
            {{/if}}
        </div>
    </div>

    <div class="stat-card stat-warning">
        <div class="stat-icon">🌾</div>
        <div class="stat-info-text">
            <div class="stat-label">Total Feed (Bags)</div>
            <div class="stat-value">{{formatNumber totalFeed}}</div>
        </div>
    </div>

    <div class="stat-card stat-success">
        <div class="stat-icon">💰</div>
        <div class="stat-info-text">
            <div class="stat-label">Today's Sales</div>
            <div class="stat-value">{{formatCurrency todaySales}}</div>
        </div>
    </div>

    <div class="stat-card stat-danger">
        <div class="stat-icon">💸</div>
        <div class="stat-info-text">
            <div class="stat-label">Today's Expenses</div>
            <div class="stat-value">{{formatCurrency todayExpenses}}</div>
        </div>
    </div>

    <div class="stat-card stat-info">
        <div class="stat-icon">📈</div>
        <div class="stat-info-text">
            <div class="stat-label">Monthly P&L</div>
            <div class="stat-value">{{formatCurrency monthProfit}}</div>
            <div class="stat-change {{#if (gte monthProfit 0)}}positive{{else}}negative{{/if}}">
                {{#if (gte monthProfit 0)}}↑ Profit{{else}}↓ Loss{{/if}}
            </div>
        </div>
    </div>
</div>

<!-- Today's Operations -->
<div class="stats-grid" style="margin-bottom: 1.75rem;">
    <div class="stat-card stat-danger">
        <div class="stat-icon">💀</div>
        <div class="stat-info-text">
            <div class="stat-label">Today's Mortality</div>
            <div class="stat-value">{{formatNumber todayMortality}}</div>
        </div>
    </div>

    <div class="stat-card stat-success">
        <div class="stat-icon">🥚</div>
        <div class="stat-info-text">
            <div class="stat-label">Eggs Collected Today</div>
            <div class="stat-value">{{formatNumber todayEggCollection}}</div>
        </div>
    </div>

    <div class="stat-card stat-warning">
        <div class="stat-icon">🌾</div>
        <div class="stat-info-text">
            <div class="stat-label">Feed Consumed Today</div>
            <div class="stat-value">{{formatNumber todayFeedConsumption}} bags</div>
        </div>
    </div>

    <div class="stat-card stat-info">
        <div class="stat-icon">📦</div>
        <div class="stat-info-text">
            <div class="stat-label">Pending Egg Orders</div>
            <div class="stat-value">{{formatNumber pendingOrders}}</div>
        </div>
    </div>
</div>

<!-- Quick Entries -->
<div class="card mb-3">
    <div class="card-header">
        <h3>⚡ Quick Entries</h3>
    </div>
    <div class="card-body">
        <div class="quick-entry-grid">
            <button class="quick-entry-btn" data-modal="modalEggCollection">
                <div class="qe-icon" style="background: var(--success-light); color: var(--success);">🥚</div>
                <div class="qe-text">
                    <h4>Egg Collection</h4>
                    <p>Record today's eggs</p>
                </div>
            </button>

            <button class="quick-entry-btn" data-modal="modalFeedConsumption">
                <div class="qe-icon" style="background: var(--warning-light); color: #b45309;">🌾</div>
                <div class="qe-text">
                    <h4>Feed Consumption</h4>
                    <p>Log feed used today</p>
                </div>
            </button>

            <button class="quick-entry-btn" data-modal="modalMortality">
                <div class="qe-icon" style="background: var(--danger-light); color: var(--danger);">💀</div>
                <div class="qe-text">
                    <h4>Bird Mortality</h4>
                    <p>Record bird deaths</p>
                </div>
            </button>

            <button class="quick-entry-btn" data-modal="modalEggSale">
                <div class="qe-icon" style="background: var(--info-light); color: var(--info);">💰</div>
                <div class="qe-text">
                    <h4>Quick Egg Sale</h4>
                    <p>Sell eggs to customer</p>
                </div>
            </button>
        </div>
    </div>
</div>

<!-- Main Dashboard Grid -->
<div class="dashboard-grid">
    <!-- Alerts -->
    <div class="card">
        <div class="card-header">
            <h3>🚨 Low Stock Alerts</h3>
        </div>
        <div class="card-body">
            {{#if lowStockAlerts.length}}
            <ul class="alert-list">
                {{#each lowStockAlerts}}
                <li class="alert-item">
                    <span class="alert-name">{{this.name}}</span>
                    <span class="alert-count">{{formatNumber this.quantity}} / {{formatNumber this.threshold}}</span>
                </li>
                {{/each}}
            </ul>
            {{else}}
            <div class="empty-state">
                <p class="text-success">✓ All stock levels are healthy</p>
            </div>
            {{/if}}
        </div>
    </div>

    <!-- Recent Activity -->
    <div class="card">
        <div class="card-header">
            <h3>📋 Recent Activity</h3>
        </div>
        <div class="card-body">
            {{#if recentActivity.length}}
            <ul class="activity-list">
                {{#each recentActivity}}
                <li class="activity-item">
                    <span
                        class="activity-dot {{#if (eq this.transaction_type 'mortality')}}red{{else if (eq this.transaction_type 'sale')}}green{{else if (eq this.transaction_type 'purchase')}}blue{{else}}yellow{{/if}}"></span>
                    <span class="activity-text">
                        {{capitalize this.transaction_type}} — {{this.quantity}} {{this.item_name}}
                        {{#if this.user_name}}<span class="text-muted"> by {{this.user_name}}</span>{{/if}}
                    </span>
                    <span class="activity-time">{{formatDate this.transaction_date}}</span>
                </li>
                {{/each}}
            </ul>
            {{else}}
            <div class="empty-state">
                <p>No recent activity</p>
            </div>
            {{/if}}
        </div>
    </div>
</div>

<!-- Quick Entry Modals -->
<!-- Egg Collection Modal -->
<div class="modal-overlay" id="modalEggCollection">
    <div class="modal">
        <div class="modal-header">
            <h3>🥚 Quick Egg Collection</h3>
            <button class="modal-close">✕</button>
        </div>
        <form action="/eggs/transaction" method="POST" data-async>
            <div class="modal-body">
                <input type="hidden" name="transaction_type" value="collection">
                <div class="form-group">
                    <label>Quantity <span class="required">*</span></label>
                    <input type="number" class="form-control" name="quantity" required min="1"
                        placeholder="Enter number of eggs">
                </div>
                <div class="form-group">
                    <label>Notes</label>
                    <textarea class="form-control" name="notes" rows="2" placeholder="Optional notes"></textarea>
                </div>
            </div>
            <div class="modal-footer">
                <button type="button" class="btn btn-outline" data-dismiss="modal">Cancel</button>
                <button type="submit" class="btn btn-success">Save Collection</button>
            </div>
        </form>
    </div>
</div>

<!-- Feed Consumption Modal -->
<div class="modal-overlay" id="modalFeedConsumption">
    <div class="modal">
        <div class="modal-header">
            <h3>🌾 Quick Feed Consumption</h3>
            <button class="modal-close">✕</button>
        </div>
        <form action="/feed/transaction" method="POST" data-async>
            <div class="modal-body">
                <input type="hidden" name="transaction_type" value="consumption">
                <div class="form-group">
                    <label>Feed Type <span class="required">*</span></label>
                    <select class="form-control" name="feed_type_id" required>
                        <option value="">Select feed type</option>
                    </select>
                </div>
                <div class="form-group">
                    <label>Quantity (Bags) <span class="required">*</span></label>
                    <input type="number" class="form-control" name="quantity" required min="0.1" step="0.1"
                        placeholder="Enter bags">
                </div>
                <div class="form-group">
                    <label>Notes</label>
                    <textarea class="form-control" name="notes" rows="2" placeholder="Optional notes"></textarea>
                </div>
            </div>
            <div class="modal-footer">
                <button type="button" class="btn btn-outline" data-dismiss="modal">Cancel</button>
                <button type="submit" class="btn btn-warning">Record Consumption</button>
            </div>
        </form>
    </div>
</div>

<!-- Mortality Modal -->
<div class="modal-overlay" id="modalMortality">
    <div class="modal">
        <div class="modal-header">
            <h3>💀 Quick Mortality Entry</h3>
            <button class="modal-close">✕</button>
        </div>
        <form action="/birds/transaction" method="POST" data-async>
            <div class="modal-body">
                <input type="hidden" name="transaction_type" value="mortality">
                <div class="form-group">
                    <label>Bird Type <span class="required">*</span></label>
                    <select class="form-control" name="bird_type_id" required>
                        <option value="">Select bird type</option>
                    </select>
                </div>
                <div class="form-group">
                    <label>Quantity <span class="required">*</span></label>
                    <input type="number" class="form-control" name="quantity" required min="1"
                        placeholder="Number of birds">
                </div>
                <div class="form-group">
                    <label>Notes</label>
                    <textarea class="form-control" name="notes" rows="2" placeholder="e.g., cause of death"></textarea>
                </div>
            </div>
            <div class="modal-footer">
                <button type="button" class="btn btn-outline" data-dismiss="modal">Cancel</button>
                <button type="submit" class="btn btn-danger">Record Mortality</button>
            </div>
        </form>
    </div>
</div>

<!-- Quick Egg Sale Modal -->
<div class="modal-overlay" id="modalEggSale">
    <div class="modal">
        <div class="modal-header">
            <h3>💰 Quick Egg Sale</h3>
            <button class="modal-close">✕</button>
        </div>
        <form action="/eggs/transaction" method="POST" data-async>
            <div class="modal-body">
                <input type="hidden" name="transaction_type" value="sale">
                <div class="form-group">
                    <label>Quantity <span class="required">*</span></label>
                    <input type="number" class="form-control" name="quantity" required min="1"
                        placeholder="Number of eggs">
                </div>
                <div class="form-group">
                    <label>Unit Price</label>
                    <input type="number" class="form-control" name="unit_price" step="0.01" placeholder="Price per egg">
                </div>
                <div class="form-group">
                    <label>Total Amount</label>
                    <input type="number" class="form-control" name="total_amount" step="0.01"
                        placeholder="Auto-calculated" readonly>
                </div>
                <div class="form-group">
                    <label>Notes</label>
                    <textarea class="form-control" name="notes" rows="2" placeholder="Optional notes"></textarea>
                </div>
            </div>
            <div class="modal-footer">
                <button type="button" class="btn btn-outline" data-dismiss="modal">Cancel</button>
                <button type="submit" class="btn btn-success">Record Sale</button>
            </div>
        </form>
    </div>
</div>

<script>
    // Populate feed type and bird type dropdowns from API
    document.addEventListener('DOMContentLoaded', async () => {
        try {
            // Fetch bird types
            const birdRes = await fetch('/birds/api/types');
            if (birdRes.ok) {
                const birdTypes = await birdRes.json();
                document.querySelectorAll('select[name="bird_type_id"]').forEach(sel => {
                    birdTypes.forEach(t => {
                        const opt = document.createElement('option');
                        opt.value = t.id;
                        opt.textContent = t.name;
                        sel.appendChild(opt);
                    });
                });
            }
        } catch (e) { console.log('Could not load bird types'); }

        try {
            // Fetch feed types
            const feedRes = await fetch('/feed/api/types');
            if (feedRes.ok) {
                const feedTypes = await feedRes.json();
                document.querySelectorAll('select[name="feed_type_id"]').forEach(sel => {
                    feedTypes.forEach(t => {
                        const opt = document.createElement('option');
                        opt.value = t.id;
                        opt.textContent = t.name;
                        sel.appendChild(opt);
                    });
                });
            }
        } catch (e) { console.log('Could not load feed types'); }
    });
</script>