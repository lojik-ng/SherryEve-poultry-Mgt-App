<div class="page-header">
    <div class="page-header-info">
        <h2>📝 Farm Journal</h2>
        <p>Daily farm notes, observations, and records</p>
    </div>
    <div class="page-header-actions"><button class="btn btn-primary" data-modal="modalAddNote">+ New Note</button></div>
</div>

<div class="filters-bar">
    <div class="form-group">
        <label>Filter by Category</label>
        <select class="form-control" onchange="window.location.href='/notes?category='+this.value">
            <option value="">All Categories</option>
            {{#each categories}}
            <option value="{{this}}" {{selected this ../selectedCategory}}>{{this}}</option>
            {{/each}}
        </select>
    </div>
</div>

<div class="card">
    <div class="card-body">
        {{#if notes.length}}
        {{#each notes}}
        <div class="activity-item"
            style="flex-direction: column; align-items: flex-start; gap: 0.5rem; padding: 1.25rem 0;">
            <div class="flex items-center justify-between w-full">
                <div class="flex items-center gap-1">
                    <span class="badge badge-info">{{this.category}}</span>
                    {{#if this.title}}<strong style="font-size: 1rem;">{{this.title}}</strong>{{/if}}
                </div>
                <div class="flex items-center gap-1">
                    <span class="text-muted" style="font-size: 0.8rem;">{{formatDate this.note_date}} ·
                        {{this.created_by_name}}</span>
                    <form action="/notes/{{this.id}}/delete" method="POST" style="display:inline">
                        <button type="submit" class="btn btn-ghost btn-sm text-danger"
                            data-confirm="Delete this note?">🗑</button>
                    </form>
                </div>
            </div>
            <p style="font-size: 0.9rem; color: var(--text-secondary); white-space: pre-wrap;">{{this.content}}</p>
        </div>
        {{/each}}
        {{else}}
        <div class="empty-state">
            <div class="empty-icon">📝</div>
            <h3>No Notes</h3>
            <p>Start your farm journal</p>
        </div>
        {{/if}}
    </div>
</div>

<div class="modal-overlay" id="modalAddNote">
    <div class="modal">
        <div class="modal-header">
            <h3>📝 New Farm Note</h3><button class="modal-close">✕</button>
        </div>
        <form action="/notes" method="POST" data-async>
            <div class="modal-body">
                <div class="form-row">
                    <div class="form-group"><label>Category</label>
                        <select class="form-control" name="category">
                            <option value="General">General</option>
                            <option value="Health">Health</option>
                            <option value="Maintenance">Maintenance</option>
                            <option value="Feed">Feed</option>
                            <option value="Vaccination">Vaccination</option>
                            <option value="Observation">Observation</option>
                        </select>
                    </div>
                    <div class="form-group"><label>Date</label><input type="date" class="form-control" name="note_date">
                    </div>
                </div>
                <div class="form-group"><label>Title</label><input type="text" class="form-control" name="title"
                        placeholder="Brief title"></div>
                <div class="form-group"><label>Content <span class="required">*</span></label><textarea
                        class="form-control" name="content" rows="5" required
                        placeholder="Write your note..."></textarea></div>
            </div>
            <div class="modal-footer"><button type="button" class="btn btn-outline"
                    data-dismiss="modal">Cancel</button><button type="submit" class="btn btn-primary">Save Note</button>
            </div>
        </form>
    </div>
</div>