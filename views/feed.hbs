<div class="page-header">
    <div class="page-header-info">
        <h2>🌾 Feed Management</h2>
        <p>Manage feed types, stock, and usage tracking</p>
    </div>
    <div class="page-header-actions">
        {{#canDo 'feed' 'create'}}
        <button class="btn btn-outline" data-modal="modalAddFeedType">+ Add Feed Type</button>
        <button class="btn btn-primary" data-modal="modalFeedPurchase">+ Purchase</button>
        <button class="btn btn-warning" data-modal="modalFeedConsume">+ Consumption</button>
        {{/canDo}}
    </div>
</div>

<div class="stats-grid">
    {{#each feedStock}}
    <div class="stat-card stat-warning">
        <div class="stat-icon">🌾</div>
        <div class="stat-info-text">
            <div class="stat-label">{{this.type_name}}</div>
            <div class="stat-value">{{formatNumber this.quantity}} bags</div>
            {{#if (lte this.quantity this.low_stock_threshold)}}
            <div class="stat-change negative">⚠ Low Stock</div>
            {{/if}}
        </div>
    </div>
    {{/each}}
</div>

<div class="grid-2 mb-3">
    <div class="card">
        <div class="card-header">
            <h3>Feed Types</h3>
        </div>
        <div class="card-body">
            {{#if feedTypes.length}}
            <div class="table-container">
                <table class="data-table">
                    <thead>
                        <tr>
                            <th>Name</th>
                            <th>Description</th>
                            <th>Status</th>
                            <th>Actions</th>
                        </tr>
                    </thead>
                    <tbody>
                        {{#each feedTypes}}
                        <tr>
                            <td><strong>{{this.name}}</strong></td>
                            <td>{{this.description}}</td>
                            <td>{{#if this.is_active}}<span class="badge badge-success">Active</span>{{else}}<span
                                    class="badge badge-danger">Inactive</span>{{/if}}</td>
                            <td>
                                {{#canDo 'feed' 'edit'}}
                                <form action="/feed/type/{{this.id}}/toggle" method="POST" style="display:inline">
                                    <button type="submit" class="btn btn-ghost btn-sm">{{#if
                                        this.is_active}}Deactivate{{else}}Activate{{/if}}</button>
                                </form>
                                {{/canDo}}
                            </td>
                        </tr>
                        {{/each}}
                    </tbody>
                </table>
            </div>
            {{else}}
            <div class="empty-state">
                <div class="empty-icon">🌾</div>
                <h3>No Feed Types</h3>
                <p>Add feed types to get started</p>
            </div>
            {{/if}}
        </div>
    </div>

    <div class="card">
        <div class="card-header">
            <h3>⚡ Quick Actions</h3>
        </div>
        <div class="card-body">
            <div class="quick-entry-grid" style="grid-template-columns: 1fr;">
                {{#canDo 'feed' 'create'}}
                <button class="quick-entry-btn" data-modal="modalFeedPurchase">
                    <div class="qe-icon" style="background: var(--info-light); color: var(--info);">🛒</div>
                    <div class="qe-text">
                        <h4>Purchase Feed</h4>
                        <p>Record feed purchase</p>
                    </div>
                </button>
                <button class="quick-entry-btn" data-modal="modalFeedConsume">
                    <div class="qe-icon" style="background: var(--warning-light); color: #b45309;">📉</div>
                    <div class="qe-text">
                        <h4>Feed Consumption</h4>
                        <p>Log feed used today</p>
                    </div>
                </button>
                <button class="quick-entry-btn" data-modal="modalFeedWaste">
                    <div class="qe-icon" style="background: var(--danger-light); color: var(--danger);">🗑</div>
                    <div class="qe-text">
                        <h4>Feed Wastage</h4>
                        <p>Record feed waste/spoilage</p>
                    </div>
                </button>
                {{else}}
                <div class="empty-state">
                    <p class="text-muted">You don't have permission to create transactions</p>
                </div>
                {{/canDo}}
            </div>
        </div>
    </div>
</div>

<div class="card">
    <div class="card-header">
        <h3>Transaction History</h3>
    </div>
    <div class="card-body">
        {{#if transactions.length}}
        <div class="table-container">
            <table class="data-table">
                <thead>
                    <tr>
                        <th>Date</th>
                        <th>Type</th>
                        <th>Feed</th>
                        <th>Qty (Bags)</th>
                        <th>Unit Price</th>
                        <th>Total</th>
                        <th>Vendor</th>
                        <th>By</th>
                    </tr>
                </thead>
                <tbody>
                    {{#each transactions}}
                    <tr>
                        <td>{{formatDate this.transaction_date}}</td>
                        <td>{{{statusBadge this.transaction_type}}}</td>
                        <td>{{this.type_name}}</td>
                        <td>{{this.quantity}}</td>
                        <td>{{#if this.unit_price}}{{formatCurrency this.unit_price}}{{else}}—{{/if}}</td>
                        <td>{{#if this.total_amount}}{{formatCurrency this.total_amount}}{{else}}—{{/if}}</td>
                        <td>{{#if this.vendor_name}}{{this.vendor_name}}{{else}}—{{/if}}</td>
                        <td>{{this.created_by_name}}</td>
                    </tr>
                    {{/each}}
                </tbody>
            </table>
        </div>
        {{else}}
        <div class="empty-state">
            <div class="empty-icon">📋</div>
            <h3>No Transactions</h3>
            <p>Record your first feed transaction</p>
        </div>
        {{/if}}
    </div>
</div>

<!-- Add Feed Type Modal -->
{{#canDo 'feed' 'create'}}
<div class="modal-overlay" id="modalAddFeedType">
    <div class="modal">
        <div class="modal-header">
            <h3>Add Feed Type</h3><button class="modal-close">✕</button>
        </div>
        <form action="/feed/type" method="POST" data-async>
            <div class="modal-body">
                <div class="form-group"><label>Name <span class="required">*</span></label><input type="text"
                        class="form-control" name="name" required placeholder="e.g., Starter, Grower, Layer"></div>
                <div class="form-group"><label>Description</label><input type="text" class="form-control"
                        name="description" placeholder="Optional"></div>
            </div>
            <div class="modal-footer"><button type="button" class="btn btn-outline"
                    data-dismiss="modal">Cancel</button><button type="submit" class="btn btn-primary">Add Type</button>
            </div>
        </form>
    </div>
</div>

<!-- Feed Purchase Modal -->
<div class="modal-overlay" id="modalFeedPurchase">
    <div class="modal">
        <div class="modal-header">
            <h3>🛒 Purchase Feed</h3><button class="modal-close">✕</button>
        </div>
        <form action="/feed/transaction" method="POST" data-async>
            <input type="hidden" name="transaction_type" value="purchase">
            <div class="modal-body">
                <div class="form-group"><label>Feed Type <span class="required">*</span></label>
                    <select class="form-control" name="feed_type_id" required>
                        {{#each feedTypes}}{{#if this.is_active}}<option value="{{this.id}}">{{this.name}}</option>
                        {{/if}}{{/each}}
                    </select>
                </div>
                <div class="form-row">
                    <div class="form-group"><label>Quantity (Bags) <span class="required">*</span></label><input
                            type="number" class="form-control" name="quantity" required min="0.1" step="0.1"></div>
                    <div class="form-group"><label>Unit Price</label><input type="number" class="form-control"
                            name="unit_price" step="0.01"></div>
                </div>
                <div class="form-group"><label>Total</label><input type="number" class="form-control"
                        name="total_amount" step="0.01" readonly></div>
                <div class="form-group"><label>Vendor</label><select class="form-control" name="vendor_id">
                        <option value="">— Select —</option>{{#each vendors}}<option value="{{this.id}}">{{this.name}}
                        </option>{{/each}}
                    </select></div>
                <div class="form-group"><label>Notes</label><textarea class="form-control" name="notes"
                        rows="2"></textarea></div>
            </div>
            <div class="modal-footer"><button type="button" class="btn btn-outline"
                    data-dismiss="modal">Cancel</button><button type="submit" class="btn btn-primary">Record
                    Purchase</button></div>
        </form>
    </div>
</div>

<!-- Feed Consumption Modal -->
<div class="modal-overlay" id="modalFeedConsume">
    <div class="modal">
        <div class="modal-header">
            <h3>📉 Feed Consumption</h3><button class="modal-close">✕</button>
        </div>
        <form action="/feed/transaction" method="POST" data-async>
            <input type="hidden" name="transaction_type" value="consumption">
            <div class="modal-body">
                <div class="form-group"><label>Feed Type <span class="required">*</span></label>
                    <select class="form-control" name="feed_type_id" required>
                        {{#each feedTypes}}{{#if this.is_active}}<option value="{{this.id}}">{{this.name}}</option>
                        {{/if}}{{/each}}
                    </select>
                </div>
                <div class="form-group"><label>Quantity (Bags) <span class="required">*</span></label><input
                        type="number" class="form-control" name="quantity" required min="0.1" step="0.1"></div>
                <div class="form-group"><label>Notes</label><textarea class="form-control" name="notes"
                        rows="2"></textarea></div>
            </div>
            <div class="modal-footer"><button type="button" class="btn btn-outline"
                    data-dismiss="modal">Cancel</button><button type="submit" class="btn btn-warning">Record
                    Consumption</button></div>
        </form>
    </div>
</div>

<!-- Feed Wastage Modal -->
<div class="modal-overlay" id="modalFeedWaste">
    <div class="modal">
        <div class="modal-header">
            <h3>🗑 Feed Wastage</h3><button class="modal-close">✕</button>
        </div>
        <form action="/feed/transaction" method="POST" data-async>
            <input type="hidden" name="transaction_type" value="wastage">
            <div class="modal-body">
                <div class="form-group"><label>Feed Type <span class="required">*</span></label>
                    <select class="form-control" name="feed_type_id" required>
                        {{#each feedTypes}}{{#if this.is_active}}<option value="{{this.id}}">{{this.name}}</option>
                        {{/if}}{{/each}}
                    </select>
                </div>
                <div class="form-group"><label>Quantity (Bags) <span class="required">*</span></label><input
                        type="number" class="form-control" name="quantity" required min="0.1" step="0.1"></div>
                <div class="form-group"><label>Notes</label><textarea class="form-control" name="notes" rows="2"
                        placeholder="Reason for wastage"></textarea></div>
            </div>
            <div class="modal-footer"><button type="button" class="btn btn-outline"
                    data-dismiss="modal">Cancel</button><button type="submit" class="btn btn-danger">Record
                    Wastage</button></div>
        </form>
    </div>
</div>
{{/canDo}}