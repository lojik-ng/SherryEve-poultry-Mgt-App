<div class="page-header">
  <div class="page-header-info">
    <h2>👥 User & Role Management</h2>
    <p>Manage system users, roles, and access control</p>
  </div>
  <div class="page-header-actions">
    {{#canDo 'admin' 'create'}}<button class="btn btn-primary" data-modal="modalAddUser">+ Add User</button>
    <button class="btn btn-outline" data-modal="modalAddRole">+ Add Role</button>{{/canDo}}
  </div>
</div>

<!-- Tabs -->
<div class="tabs mb-2">
  <button class="tab-btn {{#if (eq tab 'users')}}active{{/if}}{{#unless tab}}active{{/unless}}" data-tab="tabUsers">👤
    Users</button>
  <button class="tab-btn {{#if (eq tab 'roles')}}active{{/if}}" data-tab="tabRoles">🔐 Roles & Permissions</button>
</div>

<!-- ═══════════════════ USERS TAB ═══════════════════ -->
<div class="tab-panel {{#if (eq tab 'users')}}active{{/if}}{{#unless tab}}active{{/unless}}" id="tabUsers">
  <div class="card">
    <div class="card-body">
      {{#if users.length}}
      <div class="table-container">
        <table class="data-table">
          <thead>
            <tr>
              <th>Name</th>
              <th>Email</th>
              <th>Phone</th>
              <th>Role</th>
              <th>Status</th>
              <th>Created</th>
              <th>Actions</th>
            </tr>
          </thead>
          <tbody>
            {{#each users}}
            <tr>
              <td><strong>{{this.name}}</strong></td>
              <td>{{this.email}}</td>
              <td>{{#if this.phone}}{{this.phone}}{{else}}—{{/if}}</td>
              <td>
                {{#if this.role_names}}<span class="badge badge-primary">{{this.role_names}}</span>
                {{else}}<span class="text-muted">No role</span>{{/if}}
              </td>
              <td>
                {{#if this.is_active}}<span class="badge badge-success">Active</span>
                {{else}}<span class="badge badge-danger">Inactive</span>{{/if}}
                {{#if this.must_change_password}}<span class="badge badge-warning">Must Change PW</span>{{/if}}
              </td>
              <td>{{formatDate this.created_at}}</td>
              <td class="table-actions">
                {{#canDo 'admin' 'edit'}}
                <button class="btn btn-ghost btn-sm"
                  onclick="openEditUserModal({{this.id}}, '{{this.name}}', '{{this.email}}', '{{this.phone}}', '{{this.role_ids}}')">✏️
                  Edit</button>
                <form action="/admin/users/{{this.id}}/toggle" method="POST" style="display:inline">
                  <button type="submit" class="btn btn-ghost btn-sm">{{#if
                    this.is_active}}Deactivate{{else}}Activate{{/if}}</button>
                </form>
                <form action="/admin/users/{{this.id}}/reset-password" method="POST" style="display:inline">
                  <input type="hidden" name="new_password" value="changeme123">
                  <button type="submit" class="btn btn-ghost btn-sm text-warning"
                    data-confirm="Reset password to 'changeme123'?">🔑 Reset PW</button>
                </form>
                {{/canDo}}
              </td>
            </tr>
            {{/each}}
          </tbody>
        </table>
      </div>
      {{else}}
      <div class="empty-state">
        <div class="empty-icon">👥</div>
        <h3>No Users</h3>
      </div>
      {{/if}}
    </div>
  </div>
</div>

<!-- ═══════════════════ ROLES TAB ═══════════════════ -->
<div class="tab-panel {{#if (eq tab 'roles')}}active{{/if}}" id="tabRoles">
  {{#each roles}}
  <div class="card mb-2">
    <div class="card-header" style="display:flex; justify-content:space-between; align-items:center;">
      <div>
        <h3 style="margin:0;">{{this.name}}
          {{#if this.is_system}}<span class="badge badge-info"
            style="font-size:0.7rem; margin-left:0.5rem;">System</span>{{/if}}
        </h3>
        <p style="margin:0.25rem 0 0; font-size:0.85rem; color:var(--text-muted);">{{#if
          this.description}}{{this.description}}{{else}}No description{{/if}}</p>
      </div>
      <div class="table-actions">
        <button class="btn btn-outline btn-sm" onclick="loadRoleForEdit({{this.id}})">✏️ Edit</button>
        {{#unless this.is_system}}
        <form action="/admin/roles/{{this.id}}/delete" method="POST" style="display:inline">
          <button type="submit" class="btn btn-ghost btn-sm text-danger"
            data-confirm="Delete role '{{this.name}}'? Users with this role will lose these permissions.">🗑
            Delete</button>
        </form>
        {{/unless}}
      </div>
    </div>
  </div>
  {{/each}}

  {{#unless roles.length}}
  <div class="card">
    <div class="card-body">
      <div class="empty-state">
        <div class="empty-icon">🔐</div>
        <h3>No Roles</h3>
        <p>Create your first role</p>
      </div>
    </div>
  </div>
  {{/unless}}
</div>

<!-- ═══════════════ ADD USER MODAL ═══════════════ -->
<div class="modal-overlay" id="modalAddUser">
  <div class="modal">
    <div class="modal-header">
      <h3>Add User</h3><button class="modal-close">✕</button>
    </div>
    <form action="/admin/users" method="POST" data-async>
      <div class="modal-body">
        <div class="form-group"><label>Full Name <span class="required">*</span></label><input type="text"
            class="form-control" name="name" required></div>
        <div class="form-row">
          <div class="form-group"><label>Email <span class="required">*</span></label><input type="email"
              class="form-control" name="email" required></div>
          <div class="form-group"><label>Phone</label><input type="text" class="form-control" name="phone"></div>
        </div>
        <div class="form-group"><label>Password <span class="required">*</span></label><input type="password"
            class="form-control" name="password" required minlength="6"></div>
        <div class="form-group"><label>Role</label>
          <select class="form-control" name="role_id">
            <option value="">— No Role —</option>
            {{#each roles}}<option value="{{this.id}}">{{this.name}}</option>{{/each}}
          </select>
        </div>
        <div class="form-group">
          <label><input type="checkbox" name="must_change_password" value="1" checked> Force password change on first
            login</label>
        </div>
      </div>
      <div class="modal-footer">
        <button type="button" class="btn btn-outline" data-dismiss="modal">Cancel</button>
        <button type="submit" class="btn btn-primary">Create User</button>
      </div>
    </form>
  </div>
</div>

<!-- ═══════════════ EDIT USER MODAL ═══════════════ -->
<div class="modal-overlay" id="modalEditUser">
  <div class="modal">
    <div class="modal-header">
      <h3>Edit User</h3><button class="modal-close">✕</button>
    </div>
    <form id="editUserForm" method="POST" data-async>
      <div class="modal-body">
        <div class="form-group"><label>Full Name <span class="required">*</span></label><input type="text"
            class="form-control" name="name" id="editUserName" required></div>
        <div class="form-row">
          <div class="form-group"><label>Email <span class="required">*</span></label><input type="email"
              class="form-control" name="email" id="editUserEmail" required></div>
          <div class="form-group"><label>Phone</label><input type="text" class="form-control" name="phone"
              id="editUserPhone"></div>
        </div>
        <div class="form-group"><label>Role</label>
          <select class="form-control" name="role_id" id="editUserRole">
            <option value="">— No Role —</option>
            {{#each roles}}<option value="{{this.id}}">{{this.name}}</option>{{/each}}
          </select>
        </div>
      </div>
      <div class="modal-footer">
        <button type="button" class="btn btn-outline" data-dismiss="modal">Cancel</button>
        <button type="submit" class="btn btn-primary">Save Changes</button>
      </div>
    </form>
  </div>
</div>

<!-- ═══════════════ ADD ROLE MODAL ═══════════════ -->
<div class="modal-overlay" id="modalAddRole">
  <div class="modal modal-lg">
    <div class="modal-header">
      <h3>Add Role</h3><button class="modal-close">✕</button>
    </div>
    <form action="/admin/roles" method="POST" data-async>
      <div class="modal-body">
        <div class="form-row">
          <div class="form-group"><label>Role Name <span class="required">*</span></label><input type="text"
              class="form-control" name="name" required></div>
          <div class="form-group"><label>Description</label><input type="text" class="form-control" name="description">
          </div>
        </div>
        <h4 style="margin: 1rem 0 0.5rem; font-size: 0.95rem; color: var(--text-secondary);">Permissions</h4>
        <div class="permission-grid" id="addRolePermissions"></div>
      </div>
      <div class="modal-footer">
        <button type="button" class="btn btn-outline" data-dismiss="modal">Cancel</button>
        <button type="submit" class="btn btn-primary">Create Role</button>
      </div>
    </form>
  </div>
</div>

<!-- ═══════════════ EDIT ROLE MODAL ═══════════════ -->
<div class="modal-overlay" id="modalEditRole">
  <div class="modal modal-lg">
    <div class="modal-header">
      <h3>Edit Role</h3><button class="modal-close">✕</button>
    </div>
    <form id="editRoleForm" method="POST" data-async>
      <div class="modal-body">
        <div class="form-row">
          <div class="form-group"><label>Role Name <span class="required">*</span></label><input type="text"
              class="form-control" name="name" id="editRoleName" required></div>
          <div class="form-group"><label>Description</label><input type="text" class="form-control" name="description"
              id="editRoleDesc"></div>
        </div>
        <h4 style="margin: 1rem 0 0.5rem; font-size: 0.95rem; color: var(--text-secondary);">Permissions</h4>
        <div class="permission-grid" id="editRolePermissions"></div>
      </div>
      <div class="modal-footer">
        <button type="button" class="btn btn-outline" data-dismiss="modal">Cancel</button>
        <button type="submit" class="btn btn-primary">Save Role</button>
      </div>
    </form>
  </div>
</div>

<style>
  .permission-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(280px, 1fr));
    gap: 1rem;
  }

  .perm-module {
    background: var(--bg-elevated, #f8f9fa);
    border: 1px solid var(--border, #e2e8f0);
    border-radius: 12px;
    padding: 1rem;
  }

  .perm-module-title {
    font-weight: 600;
    font-size: 0.9rem;
    text-transform: capitalize;
    margin-bottom: 0.5rem;
    color: var(--text-primary);
    display: flex;
    align-items: center;
    gap: 0.5rem;
  }

  .perm-module-title input[type="checkbox"] {
    accent-color: var(--primary);
  }

  .perm-actions {
    display: flex;
    flex-direction: column;
    gap: 0.35rem;
    padding-left: 1.5rem;
  }

  .perm-actions label {
    font-size: 0.85rem;
    color: var(--text-secondary);
    display: flex;
    align-items: center;
    gap: 0.5rem;
    cursor: pointer;
  }

  .perm-actions label:hover {
    color: var(--text-primary);
  }

  .perm-actions input[type="checkbox"] {
    accent-color: var(--primary);
  }
</style>

<script>
  // ── Edit User Modal ─────────────────────────────────────────
  function openEditUserModal(id, name, email, phone, roleIds) {
    document.getElementById('editUserForm').action = '/admin/users/' + id + '/edit';
    document.getElementById('editUserName').value = name;
    document.getElementById('editUserEmail').value = email;
    document.getElementById('editUserPhone').value = phone || '';
    const roleSelect = document.getElementById('editUserRole');
    roleSelect.value = roleIds ? roleIds.split(',')[0] : '';
    // Show modal
    document.getElementById('modalEditUser').classList.add('active');
  }

  // ── Build permission checkboxes ─────────────────────────────
  function buildPermissionCheckboxes(containerId, permissions, checkedIds) {
    const container = document.getElementById(containerId);
    container.innerHTML = '';
    // Group by module
    const modules = {};
    permissions.forEach(p => {
      if (!modules[p.module]) modules[p.module] = [];
      modules[p.module].push(p);
    });

    for (const [mod, perms] of Object.entries(modules)) {
      const allChecked = perms.every(p => checkedIds.includes(p.id));
      const div = document.createElement('div');
      div.className = 'perm-module';
      div.innerHTML = `
      <div class="perm-module-title">
        <input type="checkbox" onchange="toggleModulePerms(this, '${mod}', '${containerId}')" ${allChecked ? 'checked' : ''}>
        ${mod.replace(/_/g, ' ')}
      </div>
      <div class="perm-actions">
        ${perms.map(p => `
          <label>
            <input type="checkbox" name="perm_${p.id}" value="1" data-module="${mod}" ${checkedIds.includes(p.id) ? 'checked' : ''}>
            ${p.action}
          </label>
        `).join('')}
      </div>
    `;
      container.appendChild(div);
    }
  }

  function toggleModulePerms(masterCheckbox, mod, containerId) {
    const container = document.getElementById(containerId);
    const checkboxes = container.querySelectorAll(`input[data-module="${mod}"]`);
    checkboxes.forEach(cb => cb.checked = masterCheckbox.checked);
  }

  // ── Load all permissions for the Add Role modal ─────────────
  (function loadAddRolePermissions() {
    fetch('/admin/roles/1', { headers: { 'Accept': 'application/json' } })
      .then(r => r.json())
      .then(data => {
        if (data.allPermissions) {
          buildPermissionCheckboxes('addRolePermissions', data.allPermissions, []);
        }
      })
      .catch(() => { });
  })();

  // ── Load role details for editing ───────────────────────────
  function loadRoleForEdit(roleId) {
    fetch('/admin/roles/' + roleId, { headers: { 'Accept': 'application/json' } })
      .then(r => r.json())
      .then(data => {
        document.getElementById('editRoleForm').action = '/admin/roles/' + roleId + '/edit';
        document.getElementById('editRoleName').value = data.role.name;
        document.getElementById('editRoleDesc').value = data.role.description || '';
        buildPermissionCheckboxes('editRolePermissions', data.allPermissions, data.rolePermissions);
        document.getElementById('modalEditRole').classList.add('active');
      })
      .catch(err => alert('Failed to load role details'));
  }
</script>