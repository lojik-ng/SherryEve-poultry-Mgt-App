<div class="page-header">
    <div class="page-header-info">
        <h2>🏪 Vendor Management</h2>
        <p>Manage your suppliers and purchase partners</p>
    </div>
    <div class="page-header-actions"><button class="btn btn-primary" data-modal="modalAddVendor">+ Add Vendor</button>
    </div>
</div>

<div class="card">
    <div class="card-body">
        {{#if vendors.length}}
        <div class="table-container">
            <table class="data-table">
                <thead>
                    <tr>
                        <th>Name</th>
                        <th>Phone</th>
                        <th>Email</th>
                        <th>Address</th>
                        <th>Added</th>
                        <th>Actions</th>
                    </tr>
                </thead>
                <tbody>
                    {{#each vendors}}
                    <tr>
                        <td><strong>{{this.name}}</strong></td>
                        <td>{{#if this.phone}}{{this.phone}}{{else}}—{{/if}}</td>
                        <td>{{#if this.email}}{{this.email}}{{else}}—{{/if}}</td>
                        <td>{{#if this.address}}{{truncate this.address 30}}{{else}}—{{/if}}</td>
                        <td>{{formatDate this.created_at}}</td>
                        <td class="table-actions">
                            <form action="/vendors/{{this.id}}/delete" method="POST" style="display:inline">
                                <button type="submit" class="btn btn-ghost btn-sm text-danger"
                                    data-confirm="Delete this vendor?">🗑</button>
                            </form>
                        </td>
                    </tr>
                    {{/each}}
                </tbody>
            </table>
        </div>
        {{else}}
        <div class="empty-state">
            <div class="empty-icon">🏪</div>
            <h3>No Vendors</h3>
            <p>Add your first vendor</p>
        </div>
        {{/if}}
    </div>
</div>

<div class="modal-overlay" id="modalAddVendor">
    <div class="modal">
        <div class="modal-header">
            <h3>Add Vendor</h3><button class="modal-close">✕</button>
        </div>
        <form action="/vendors" method="POST" data-async>
            <div class="modal-body">
                <div class="form-group"><label>Name <span class="required">*</span></label><input type="text"
                        class="form-control" name="name" required></div>
                <div class="form-row">
                    <div class="form-group"><label>Phone</label><input type="text" class="form-control" name="phone">
                    </div>
                    <div class="form-group"><label>Email</label><input type="email" class="form-control" name="email">
                    </div>
                </div>
                <div class="form-group"><label>Address</label><textarea class="form-control" name="address"
                        rows="2"></textarea></div>
                <div class="form-group"><label>Notes</label><textarea class="form-control" name="notes"
                        rows="2"></textarea></div>
            </div>
            <div class="modal-footer"><button type="button" class="btn btn-outline"
                    data-dismiss="modal">Cancel</button><button type="submit" class="btn btn-primary">Add
                    Vendor</button></div>
        </form>
    </div>
</div>