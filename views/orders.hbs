<div class="page-header">
    <div class="page-header-info">
        <h2>📦 Egg Orders</h2>
        <p>Manage egg orders and deliveries — {{pendingCount}} pending</p>
    </div>
    <div class="page-header-actions"><button class="btn btn-primary" data-modal="modalCreateOrder">+ New Order</button>
    </div>
</div>

<div class="card">
    <div class="card-body">
        {{#if orders.length}}
        <div class="table-container">
            <table class="data-table">
                <thead>
                    <tr>
                        <th>Order #</th>
                        <th>Customer</th>
                        <th>Quantity</th>
                        <th>Delivery Date</th>
                        <th>Status</th>
                        <th>Created</th>
                        <th>Actions</th>
                    </tr>
                </thead>
                <tbody>
                    {{#each orders}}
                    <tr>
                        <td><strong>#{{this.id}}</strong></td>
                        <td>{{#if this.customer_name}}{{this.customer_name}}{{else}}—{{/if}}</td>
                        <td>{{formatNumber this.quantity}}</td>
                        <td>{{formatDate this.expected_delivery_date}}</td>
                        <td>{{{statusBadge this.status}}}</td>
                        <td>{{formatDate this.created_at}}</td>
                        <td class="table-actions">
                            {{#if (eq this.status 'pending')}}
                            <form action="/orders/{{this.id}}/fulfill" method="POST" style="display:inline">
                                <button type="submit" class="btn btn-success btn-sm"
                                    data-confirm="Fulfill this order? Stock will be deducted.">✓ Fulfill</button>
                            </form>
                            <form action="/orders/{{this.id}}/cancel" method="POST" style="display:inline">
                                <button type="submit" class="btn btn-ghost btn-sm text-danger"
                                    data-confirm="Cancel this order?">✕ Cancel</button>
                            </form>
                            {{/if}}
                        </td>
                    </tr>
                    {{/each}}
                </tbody>
            </table>
        </div>
        {{else}}
        <div class="empty-state">
            <div class="empty-icon">📦</div>
            <h3>No Orders</h3>
            <p>Create your first egg order</p>
        </div>
        {{/if}}
    </div>
</div>

<div class="modal-overlay" id="modalCreateOrder">
    <div class="modal">
        <div class="modal-header">
            <h3>Create Egg Order</h3><button class="modal-close">✕</button>
        </div>
        <form action="/orders" method="POST" data-async>
            <div class="modal-body">
                <div class="form-group"><label>Customer</label>
                    <select class="form-control" name="customer_id">
                        <option value="">— Select —</option>
                        {{#each customers}}<option value="{{this.id}}">{{this.name}}</option>{{/each}}
                    </select>
                </div>
                <div class="form-group"><label>Quantity <span class="required">*</span></label><input type="number"
                        class="form-control" name="quantity" required min="1"></div>
                <div class="form-group"><label>Expected Delivery Date <span class="required">*</span></label><input
                        type="date" class="form-control" name="expected_delivery_date" required></div>
                <div class="form-group"><label>Notes</label><textarea class="form-control" name="notes"
                        rows="2"></textarea></div>
            </div>
            <div class="modal-footer"><button type="button" class="btn btn-outline"
                    data-dismiss="modal">Cancel</button><button type="submit" class="btn btn-primary">Create
                    Order</button></div>
        </form>
    </div>
</div>