<div class="page-header">
    <div class="page-header-info">
        <h2>📈 Reports</h2>
        <p>Generate and export farm reports</p>
    </div>
</div>

<div class="grid-3">
    <!-- Bird Reports -->
    <div class="card">
        <div class="card-header">
            <h3>🐔 Bird Reports</h3>
        </div>
        <div class="card-body">
            <a href="/reports/bird-stock" class="quick-entry-btn"
                style="margin-bottom: 0.75rem; text-decoration: none;">
                <div class="qe-icon" style="background: var(--primary-50); color: var(--primary);">📊</div>
                <div class="qe-text">
                    <h4>Bird Stock Summary</h4>
                    <p>Current stock levels</p>
                </div>
            </a>
            <a href="/reports/bird-transactions" class="quick-entry-btn"
                style="margin-bottom: 0.75rem; text-decoration: none;">
                <div class="qe-icon" style="background: var(--info-light); color: var(--info);">📋</div>
                <div class="qe-text">
                    <h4>Bird Transactions</h4>
                    <p>Purchase, sale, mortality</p>
                </div>
            </a>
            <a href="/reports/mortality" class="quick-entry-btn" style="text-decoration: none;">
                <div class="qe-icon" style="background: var(--danger-light); color: var(--danger);">💀</div>
                <div class="qe-text">
                    <h4>Mortality Report</h4>
                    <p>Bird death records</p>
                </div>
            </a>
        </div>
    </div>

    <!-- Egg Reports -->
    <div class="card">
        <div class="card-header">
            <h3>🥚 Egg Reports</h3>
        </div>
        <div class="card-body">
            <a href="/reports/egg-production" class="quick-entry-btn" style="text-decoration: none;">
                <div class="qe-icon" style="background: var(--success-light); color: var(--success);">📈</div>
                <div class="qe-text">
                    <h4>Egg Production</h4>
                    <p>Collection, sales, losses</p>
                </div>
            </a>
        </div>
    </div>

    <!-- Financial Reports -->
    <div class="card">
        <div class="card-header">
            <h3>💰 Financial Reports</h3>
        </div>
        <div class="card-body">
            <a href="/reports/profit-loss" class="quick-entry-btn"
                style="margin-bottom: 0.75rem; text-decoration: none;">
                <div class="qe-icon" style="background: var(--success-light); color: var(--success);">📊</div>
                <div class="qe-text">
                    <h4>Profit & Loss</h4>
                    <p>Income vs expenses</p>
                </div>
            </a>
            <a href="/reports/feed-consumption" class="quick-entry-btn" style="text-decoration: none;">
                <div class="qe-icon" style="background: var(--warning-light); color: #b45309;">🌾</div>
                <div class="qe-text">
                    <h4>Feed Consumption</h4>
                    <p>Feed usage by type</p>
                </div>
            </a>
        </div>
    </div>
</div>