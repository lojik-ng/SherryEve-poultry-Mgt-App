<div class="page-header">
    <div class="page-header-info">
        <h2>🐔 Bird Management</h2>
        <p>Manage bird types, stock levels, and transactions</p>
    </div>
    <div class="page-header-actions">
        {{#canDo 'birds' 'create'}}<button class="btn btn-outline" data-modal="modalAddBirdType">+ Add Bird
            Type</button>
        <button class="btn btn-primary" data-modal="modalBirdTransaction">+ Record Transaction</button>{{/canDo}}
    </div>
</div>

<!-- Stock Overview -->
<div class="stats-grid">
    {{#each birdStock}}
    <div class="stat-card stat-primary">
        <div class="stat-icon">🐔</div>
        <div class="stat-info-text">
            <div class="stat-label">{{this.type_name}}</div>
            <div class="stat-value">{{formatNumber this.quantity}}</div>
            {{#if (lte this.quantity this.low_stock_threshold)}}
            <div class="stat-change negative">⚠ Low Stock</div>
            {{/if}}
        </div>
    </div>
    {{/each}}
</div>

<!-- Bird Types -->
<div class="grid-2 mb-3">
    <div class="card">
        <div class="card-header">
            <h3>Bird Types</h3>
        </div>
        <div class="card-body">
            {{#if birdTypes.length}}
            <div class="table-container">
                <table class="data-table">
                    <thead>
                        <tr>
                            <th>Name</th>
                            <th>Description</th>
                            <th>Status</th>
                            <th>Actions</th>
                        </tr>
                    </thead>
                    <tbody>
                        {{#each birdTypes}}
                        <tr>
                            <td><strong>{{this.name}}</strong></td>
                            <td>{{this.description}}</td>
                            <td>
                                {{#if this.is_active}}
                                <span class="badge badge-success">Active</span>
                                {{else}}
                                <span class="badge badge-danger">Inactive</span>
                                {{/if}}
                            </td>
                            <td>
                                {{#canDo 'birds' 'edit'}}<form action="/birds/type/{{this.id}}/toggle" method="POST"
                                    style="display:inline">
                                    <button type="submit" class="btn btn-ghost btn-sm">
                                        {{#if this.is_active}}Deactivate{{else}}Activate{{/if}}
                                    </button>
                                </form>{{/canDo}}
                            </td>
                        </tr>
                        {{/each}}
                    </tbody>
                </table>
            </div>
            {{else}}
            <div class="empty-state">
                <div class="empty-icon">🐔</div>
                <h3>No Bird Types</h3>
                <p>Add bird types to get started</p>
            </div>
            {{/if}}
        </div>
    </div>

    <!-- Quick Stats -->
    <div class="card">
        <div class="card-header">
            <h3>⚡ Quick Actions</h3>
        </div>
        <div class="card-body">
            <div class="quick-entry-grid" style="grid-template-columns: 1fr;">
                {{#canDo 'birds' 'create'}}
                <button class="quick-entry-btn" data-modal="modalBirdPurchase">
                    <div class="qe-icon" style="background: var(--info-light); color: var(--info);">🛒</div>
                    <div class="qe-text">
                        <h4>Purchase Birds</h4>
                        <p>Record bird purchase from vendor</p>
                    </div>
                </button>
                <button class="quick-entry-btn" data-modal="modalBirdSale">
                    <div class="qe-icon" style="background: var(--success-light); color: var(--success);">💰</div>
                    <div class="qe-text">
                        <h4>Sell Birds</h4>
                        <p>Record bird sale to customer</p>
                    </div>
                </button>
                <button class="quick-entry-btn" data-modal="modalBirdMortality">
                    <div class="qe-icon" style="background: var(--danger-light); color: var(--danger);">💀</div>
                    <div class="qe-text">
                        <h4>Record Mortality</h4>
                        <p>Log bird deaths</p>
                    </div>
                </button>
                {{else}}
                <div class="empty-state">
                    <p class="text-muted">You don't have permission to create transactions</p>
                </div>
                {{/canDo}}
            </div>
        </div>
    </div>
</div>

<!-- Transaction History -->
<div class="card">
    <div class="card-header">
        <h3>Transaction History</h3>
    </div>
    <div class="card-body">
        {{#if transactions.length}}
        <div class="table-container">
            <table class="data-table" id="birdTransTable">
                <thead>
                    <tr>
                        <th>Date</th>
                        <th>Type</th>
                        <th>Bird Type</th>
                        <th>Qty</th>
                        <th>Unit Price</th>
                        <th>Total</th>
                        <th>Vendor/Customer</th>
                        <th>By</th>
                    </tr>
                </thead>
                <tbody>
                    {{#each transactions}}
                    <tr>
                        <td>{{formatDate this.transaction_date}}</td>
                        <td>{{{statusBadge this.transaction_type}}}</td>
                        <td>{{this.type_name}}</td>
                        <td>{{formatNumber this.quantity}}</td>
                        <td>{{#if this.unit_price}}{{formatCurrency this.unit_price}}{{else}}—{{/if}}</td>
                        <td>{{#if this.total_amount}}{{formatCurrency this.total_amount}}{{else}}—{{/if}}</td>
                        <td>{{#if this.vendor_name}}{{this.vendor_name}}{{else if
                            this.customer_name}}{{this.customer_name}}{{else}}—{{/if}}</td>
                        <td>{{this.created_by_name}}</td>
                    </tr>
                    {{/each}}
                </tbody>
            </table>
        </div>
        {{else}}
        <div class="empty-state">
            <div class="empty-icon">📋</div>
            <h3>No Transactions Yet</h3>
            <p>Record your first bird transaction</p>
        </div>
        {{/if}}
    </div>
</div>

<!-- Add Bird Type Modal -->
{{#canDo 'birds' 'create'}}
<div class="modal-overlay" id="modalAddBirdType">
    <div class="modal">
        <div class="modal-header">
            <h3>Add Bird Type</h3>
            <button class="modal-close">✕</button>
        </div>
        <form action="/birds/type" method="POST" data-async>
            <div class="modal-body">
                <div class="form-group">
                    <label>Name <span class="required">*</span></label>
                    <input type="text" class="form-control" name="name" required placeholder="e.g., Layers, Broilers">
                </div>
                <div class="form-group">
                    <label>Description</label>
                    <input type="text" class="form-control" name="description" placeholder="Optional description">
                </div>
            </div>
            <div class="modal-footer">
                <button type="button" class="btn btn-outline" data-dismiss="modal">Cancel</button>
                <button type="submit" class="btn btn-primary">Add Type</button>
            </div>
        </form>
    </div>
</div>

<div class="modal-overlay" id="modalBirdTransaction">
    <div class="modal">
        <div class="modal-header">
            <h3>Record Bird Transaction</h3>
            <button class="modal-close">✕</button>
        </div>
        <form action="/birds/transaction" method="POST" data-async>
            <div class="modal-body">
                <div class="form-row">
                    <div class="form-group">
                        <label>Transaction Type <span class="required">*</span></label>
                        <select class="form-control" name="transaction_type" required id="birdTxnType">
                            <option value="purchase">Purchase</option>
                            <option value="sale">Sale</option>
                            <option value="mortality">Mortality</option>
                        </select>
                    </div>
                    <div class="form-group">
                        <label>Bird Type <span class="required">*</span></label>
                        <select class="form-control" name="bird_type_id" required>
                            {{#each birdTypes}}
                            {{#if this.is_active}}
                            <option value="{{this.id}}">{{this.name}}</option>
                            {{/if}}
                            {{/each}}
                        </select>
                    </div>
                </div>
                <div class="form-row">
                    <div class="form-group">
                        <label>Quantity <span class="required">*</span></label>
                        <input type="number" class="form-control" name="quantity" required min="1">
                    </div>
                    <div class="form-group">
                        <label>Unit Price</label>
                        <input type="number" class="form-control" name="unit_price" step="0.01">
                    </div>
                </div>
                <div class="form-group">
                    <label>Total Amount</label>
                    <input type="number" class="form-control" name="total_amount" step="0.01" readonly>
                </div>
                <div class="form-group">
                    <label>Vendor</label>
                    <select class="form-control" name="vendor_id">
                        <option value="">— Select —</option>
                        {{#each vendors}}
                        <option value="{{this.id}}">{{this.name}}</option>
                        {{/each}}
                    </select>
                </div>
                <div class="form-group">
                    <label>Customer</label>
                    <select class="form-control" name="customer_id">
                        <option value="">— Select —</option>
                        {{#each customers}}
                        <option value="{{this.id}}">{{this.name}}</option>
                        {{/each}}
                    </select>
                </div>
                <div class="form-group">
                    <label>Date</label>
                    <input type="date" class="form-control" name="transaction_date">
                </div>
                <div class="form-group">
                    <label>Notes</label>
                    <textarea class="form-control" name="notes" rows="2"></textarea>
                </div>
            </div>
            <div class="modal-footer">
                <button type="button" class="btn btn-outline" data-dismiss="modal">Cancel</button>
                <button type="submit" class="btn btn-primary">Save Transaction</button>
            </div>
        </form>
    </div>
</div>

<div class="modal-overlay" id="modalBirdPurchase">
    <div class="modal">
        <div class="modal-header">
            <h3>🛒 Purchase Birds</h3>
            <button class="modal-close">✕</button>
        </div>
        <form action="/birds/transaction" method="POST" data-async>
            <input type="hidden" name="transaction_type" value="purchase">
            <div class="modal-body">
                <div class="form-group">
                    <label>Bird Type <span class="required">*</span></label>
                    <select class="form-control" name="bird_type_id" required>
                        {{#each birdTypes}}{{#if this.is_active}}<option value="{{this.id}}">{{this.name}}</option>
                        {{/if}}{{/each}}
                    </select>
                </div>
                <div class="form-row">
                    <div class="form-group">
                        <label>Quantity <span class="required">*</span></label>
                        <input type="number" class="form-control" name="quantity" required min="1">
                    </div>
                    <div class="form-group">
                        <label>Unit Price</label>
                        <input type="number" class="form-control" name="unit_price" step="0.01">
                    </div>
                </div>
                <div class="form-group">
                    <label>Total Amount</label>
                    <input type="number" class="form-control" name="total_amount" step="0.01" readonly>
                </div>
                <div class="form-group">
                    <label>Vendor</label>
                    <select class="form-control" name="vendor_id">
                        <option value="">— Select —</option>
                        {{#each vendors}}<option value="{{this.id}}">{{this.name}}</option>{{/each}}
                    </select>
                </div>
                <div class="form-group">
                    <label>Notes</label>
                    <textarea class="form-control" name="notes" rows="2"></textarea>
                </div>
            </div>
            <div class="modal-footer">
                <button type="button" class="btn btn-outline" data-dismiss="modal">Cancel</button>
                <button type="submit" class="btn btn-primary">Record Purchase</button>
            </div>
        </form>
    </div>
</div>

<!-- Bird Sale Modal -->
<div class="modal-overlay" id="modalBirdSale">
    <div class="modal">
        <div class="modal-header">
            <h3>💰 Sell Birds</h3>
            <button class="modal-close">✕</button>
        </div>
        <form action="/birds/transaction" method="POST" data-async>
            <input type="hidden" name="transaction_type" value="sale">
            <div class="modal-body">
                <div class="form-group">
                    <label>Bird Type <span class="required">*</span></label>
                    <select class="form-control" name="bird_type_id" required>
                        {{#each birdTypes}}{{#if this.is_active}}<option value="{{this.id}}">{{this.name}}</option>
                        {{/if}}{{/each}}
                    </select>
                </div>
                <div class="form-row">
                    <div class="form-group">
                        <label>Quantity <span class="required">*</span></label>
                        <input type="number" class="form-control" name="quantity" required min="1">
                    </div>
                    <div class="form-group">
                        <label>Unit Price</label>
                        <input type="number" class="form-control" name="unit_price" step="0.01">
                    </div>
                </div>
                <div class="form-group">
                    <label>Total Amount</label>
                    <input type="number" class="form-control" name="total_amount" step="0.01" readonly>
                </div>
                <div class="form-group">
                    <label>Customer</label>
                    <select class="form-control" name="customer_id">
                        <option value="">— Select —</option>
                        {{#each customers}}<option value="{{this.id}}">{{this.name}}</option>{{/each}}
                    </select>
                </div>
                <div class="form-group">
                    <label>Notes</label>
                    <textarea class="form-control" name="notes" rows="2"></textarea>
                </div>
            </div>
            <div class="modal-footer">
                <button type="button" class="btn btn-outline" data-dismiss="modal">Cancel</button>
                <button type="submit" class="btn btn-success">Record Sale</button>
            </div>
        </form>
    </div>
</div>

<!-- Bird Mortality Modal -->
<div class="modal-overlay" id="modalBirdMortality">
    <div class="modal">
        <div class="modal-header">
            <h3>💀 Record Mortality</h3>
            <button class="modal-close">✕</button>
        </div>
        <form action="/birds/transaction" method="POST" data-async>
            <input type="hidden" name="transaction_type" value="mortality">
            <div class="modal-body">
                <div class="form-group">
                    <label>Bird Type <span class="required">*</span></label>
                    <select class="form-control" name="bird_type_id" required>
                        {{#each birdTypes}}{{#if this.is_active}}<option value="{{this.id}}">{{this.name}}</option>
                        {{/if}}{{/each}}
                    </select>
                </div>
                <div class="form-group">
                    <label>Quantity <span class="required">*</span></label>
                    <input type="number" class="form-control" name="quantity" required min="1">
                </div>
                <div class="form-group">
                    <label>Notes</label>
                    <textarea class="form-control" name="notes" rows="2"
                        placeholder="Cause of death, observations..."></textarea>
                </div>
            </div>
            <div class="modal-footer">
                <button type="button" class="btn btn-outline" data-dismiss="modal">Cancel</button>
                <button type="submit" class="btn btn-danger">Record Mortality</button>
            </div>
        </form>
    </div>
</div>
{{/canDo}}